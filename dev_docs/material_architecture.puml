@startuml Material Model Architecture - Overview

skinparam backgroundColor white
skinparam classBorderColor black
skinparam classBackgroundColor white
skinparam classArrowColor black
skinparam shadowing false

title Material Model Architecture - Component Overview

' ===== Use Case Context (Determines Safety Level) =====
class AssessmentContext <<Context>> #E1F5FE {
    + use_case: UseCase
    + default_strength_level: str
    --
    + get_strength_level(): str
}

enum UseCase {
    ULS_DESIGN
    SLS_VERIFICATION
    TEACHING
    CALIBRATION
    PREDICTION
}

note right of AssessmentContext
  <b>User's Entry Point</b>
  
  Use case determines safety level:
  - ULS → 'design' (f_cd, f_yd)
  - SLS → 'characteristic' (f_ck, f_uk)
  - TEACHING → user selects
  - CALIBRATION → 'mean' (f_cm)
  - PREDICTION → 'mean' (f_cm)
  
  User can override default if needed
end note

' ===== Base Material Model Interface =====
abstract class MaterialModel <<interface>> #EEEEEE {
    + constitutive_eq: SymbolicExpression
    {abstract} + get_sig(eps: ndarray): ndarray
    {abstract} + get_latex(): str
    + plot(ax, label)
}

note right of MaterialModel
  <b>Core Interface</b>
  
  All material models must:
  - Evaluate stress for given strain
  - Provide LaTeX representation
  - Support plotting
end note

' ===== Products with Model Registry =====
class ConcreteProduct <<Product>> #E8F5E9 {
    + grade: str
    + f_ck: float
    + density: float
    --
    + AVAILABLE_MODELS: dict
    --
    + create_model(type, context)
    + list_available_models(): list
}

note left of ConcreteProduct
  <b>Model Registry Pattern</b>
  
  AVAILABLE_MODELS = {
    'ec2_monolithic': EC2ConcreteAdapter,        # All-in-one (existing)
    'parabola_rectangle': ConcreteParabolaAdapter,  # Standalone compression
    'bilinear': ConcreteBilinearAdapter,           # Standalone compression
    'parabola_drop': ConcreteParabolaDropAdapter,  # Standalone compression (nonlinear)
    'composed': ConcreteComposedAdapter            # Custom comp+tension mix
  }
  
  Example:
  product = ConcreteProduct("C30/37")
  context = AssessmentContext(UseCase.ULS_DESIGN)
  
  # Option 1: Monolithic all-in-one (existing model)
  model = product.create_model('ec2_monolithic', context)
  
  # Option 2: Standalone compression law (returns 0 for eps>0)
  model = product.create_model('parabola_rectangle', context)
  model = product.create_model('bilinear', context)
  model = product.create_model('parabola_drop', context)  # For nonlinear analysis
  
  # Option 3: Composed with custom mix (flexible)
  model = product.create_model('composed', context,
      compression='parabola_rectangle',
      tension='linear'
  )
end note

class SteelProduct <<Product>> #E8F5E9 {
    + grade: str
    + f_uk: float
    + f_tk: float
    + E_s: float
    --
    + AVAILABLE_MODELS: dict
    --
    + create_model(type, context)
    + list_available_models(): list
}

note left of SteelProduct
  <b>Model Registry Pattern</b>
  
  AVAILABLE_MODELS = {
    'bilinear': SteelBilinearAdapter,
    'bilinear_hardening': SteelBilinearHardeningAdapter
  }
  
  Example:
  product = SteelProduct("B500B")
  context = AssessmentContext(UseCase.ULS_DESIGN)
  model = product.create_model('bilinear_hardening', context)
end note

' ===== Product Adapters =====
abstract class ProductAdapter <<Adapter>> #FFF3E0 {
    + product: Product
    {abstract} + extract_params(): dict
}

class ConcreteParabolaAdapter <<Adapter>> #FFF3E0 {
    + product: ConcreteProduct
    + extract_params(): dict
}

class ConcreteBilinearAdapter <<Adapter>> #FFF3E0 {
    + product: ConcreteProduct
    + extract_params(): dict
}

class ConcreteParabolaDropAdapter <<Adapter>> #FFF3E0 {
    + product: ConcreteProduct
    + extract_params(): dict
}

class ConcreteComposedAdapter <<Adapter>> #FFF3E0 {
    + product: ConcreteProduct
    + compression_type: str
    + tension_type: str
    + extract_params(): dict
}

class EC2ConcreteAdapter <<Adapter>> #FFF3E0 {
    + product: ConcreteProduct
    + extract_params(): dict
}

note right of EC2ConcreteAdapter
  <b>Monolithic Model Adapter</b>
  
  Extracts params for all-in-one EC2Concrete:
  - f_ck
  - factor (from context)
  - Optional: E_cc, E_ct, eps_cr, eps_tu
end note

class SteelBilinearAdapter <<Adapter>> #FFF3E0 {
    + product: SteelProduct
    + extract_params(): dict
}

class SteelBilinearHardeningAdapter <<Adapter>> #FFF3E0 {
    + product: SteelProduct
    + extract_params(): dict
}

' ===== Concrete Material Models =====

' --- Compression Laws (3 variants) ---
abstract class CompressionLaw <<Model>> #E3F2FD {
    + f_ck: float
}

class EC2ParabolaRectangle <<Model>> #E3F2FD {
    + n: float
    + eps_c1: float
    + eps_cu1: float
}

class EC2Bilinear <<Model>> #E3F2FD {
    + E_c: float
    + eps_cu: float
}

class EC2ParabolaDrop <<Model>> #E3F2FD {
    + eps_c1: float
    + eps_cu: float
    + k: float
}

' --- Tension Laws (2 variants) ---
abstract class TensionLaw <<Model>> #E3F2FD {
    + f_ctk: float
}

class LinearTension <<Model>> #E3F2FD {
    + E_ct: float
}

class FiberTension <<Model>> #E3F2FD {
    + sigma_plateau: float
    + eps_tu: float
}

' --- Monolithic Concrete Model (Existing) ---
class EC2Concrete <<Monolithic>> #E3F2FD {
    + f_ck: float
    + factor: float
    + mu: float
    + E_cc: float
    + E_ct: float
    --
    + symbolic_stress: SymbolicExpression
    + get_sig(eps): ndarray
    + get_E_t(eps): ndarray
}

note right of EC2Concrete
  <b>Monolithic Model (Existing)</b>
  
  All-in-one concrete model:
  - Compression: EC2 parabola-rectangle
  - Tension: Linear + post-crack softening
  - Both behaviors in single class
  
  User cannot mix compression/tension types
end note

' ===== Steel Material Models =====
class BilinearSteel <<Model>> #E3F2FD {
    + f_uk: float
    + E_s: float
    + eps_y: float
    + eps_u: float
}

note right of BilinearSteel
  <b>Elastic-Perfectly-Plastic</b>
  
  σ = E_s·ε  (ε ≤ ε_y)
  σ = f_y     (ε_y < ε ≤ ε_u)
  σ = 0       (ε > ε_u)
  
  f_uk = characteristic strength
  No strain hardening
end note

class BilinearSteelHardening <<Model>> #E3F2FD {
    + f_uk: float
    + f_tk: float
    + E_s: float
    + E_sh: float
    + eps_y: float
    + eps_u: float
}

note right of BilinearSteelHardening
  <b>Elastic-Plastic-Hardening</b>
  
  σ = E_s·ε               (ε ≤ ε_y)
  σ = f_y + E_sh·(ε-ε_y)  (ε_y < ε ≤ ε_u)
  
  f_uk = characteristic yield
  f_tk = characteristic ultimate
  E_sh = hardening modulus
end note

' ===== Safety Adapters =====
abstract class SafetyAdapter <<Adapter>> #F3E5F5 {
    + model: MaterialModel
    + strength_level: str
    {abstract} + get_adjusted_model(): MaterialModel
}

class ConcreteCompressionSafety <<Adapter>> #F3E5F5 {
    + apply_factors()
}

class ConcreteTensionSafety <<Adapter>> #F3E5F5 {
    + apply_factors()
}

class SteelSafety <<Adapter>> #F3E5F5 {
    + apply_factors()
}

' ===== Safety Factors Dictionary =====
class SAFETY_FACTORS <<Dictionary>> #FFF9C4 {
    + concrete_compression
    + concrete_tension
    + steel
}

note left of SAFETY_FACTORS
  <b>Only safety coefficients!</b>
  
  Material strengths (f_ck, f_uk)
  come from product.
  
  Contains:
  - alpha_cc, gamma_c (concrete)
  - gamma_s (steel)
end note

' ===== Composed Models =====
class ComposedConcrete <<Composed>> #FCE4EC {
    + f_ck: float
    + compression: CompressionLaw
    + tension: TensionLaw
    + strength_level: str
    + with_strength_level(): ComposedConcrete
}

note bottom of ComposedConcrete
  <b>Composed Model (New Design)</b>
  
  Flexible composition pattern:
  get_sig(eps):
    if eps < 0: compression.get_sig(eps)
    if eps > 0: tension.get_sig(eps)
  
  Can mix any compression + tension:
  - ParabolaRectangle + Linear
  - ParabolaRectangle + Fiber
  - Bilinear + Linear
  - etc. (3 × 2 = 6 combinations)
end note

' ===== Inheritance Relationships =====
MaterialModel <|-- CompressionLaw
MaterialModel <|-- TensionLaw
MaterialModel <|-- BilinearSteel
MaterialModel <|-- BilinearSteelHardening
MaterialModel <|-- EC2Concrete
MaterialModel <|-- ComposedConcrete

CompressionLaw <|-- EC2ParabolaRectangle
CompressionLaw <|-- EC2Bilinear
CompressionLaw <|-- EC2ParabolaDrop

TensionLaw <|-- LinearTension
TensionLaw <|-- FiberTension

ProductAdapter <|-- ConcreteParabolaAdapter
ProductAdapter <|-- ConcreteBilinearAdapter
ProductAdapter <|-- ConcreteParabolaDropAdapter
ProductAdapter <|-- ConcreteComposedAdapter
ProductAdapter <|-- EC2ConcreteAdapter
ProductAdapter <|-- SteelBilinearAdapter
ProductAdapter <|-- SteelBilinearHardeningAdapter

SafetyAdapter <|-- ConcreteCompressionSafety
SafetyAdapter <|-- ConcreteTensionSafety
SafetyAdapter <|-- SteelSafety

' ===== Association Relationships =====
AssessmentContext *-- UseCase : defines
AssessmentContext ..> ConcreteProduct : <<provides context to>>
AssessmentContext ..> SteelProduct : <<provides context to>>

ConcreteProduct ..> ProductAdapter : <<registry lookup>>
SteelProduct ..> ProductAdapter : <<registry lookup>>

ConcreteParabolaAdapter ..> EC2ParabolaRectangle : <<builds>>
ConcreteBilinearAdapter ..> EC2Bilinear : <<builds>>
ConcreteParabolaDropAdapter ..> EC2ParabolaDrop : <<builds>>
ConcreteComposedAdapter ..> ComposedConcrete : <<builds>>
EC2ConcreteAdapter ..> EC2Concrete : <<builds>>
SteelBilinearAdapter ..> BilinearSteel : <<builds>>
SteelBilinearHardeningAdapter ..> BilinearSteelHardening : <<builds>>

EC2ParabolaRectangle ..> SafetyAdapter : <<wrapped by>>
EC2Bilinear ..> SafetyAdapter : <<wrapped by>>
EC2Concrete ..> SafetyAdapter : <<wrapped by>>
LinearTension ..> SafetyAdapter : <<wrapped by>>
BilinearSteel ..> SafetyAdapter : <<wrapped by>>
BilinearSteelHardening ..> SafetyAdapter : <<wrapped by>>

SafetyAdapter ..> SAFETY_FACTORS : <<uses>>
SafetyAdapter ..> AssessmentContext : <<reads strength_level from>>

ComposedConcrete *-- CompressionLaw : composes
ComposedConcrete *-- TensionLaw : composes

@enduml
